{
  "name": "playwright-demo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test && npx playwright show-report",
    "test:practice": "npx ts-node",
    "test:allure": "npx playwright test --reporter=line,allure-playwright",
    "report:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "report:open": "allure open ./allure-report",
    "report:html": "playwright show-report",
    "report:full": "npm run test:allure && npm run report:generate && npm run report:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.5.2",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.0",
    "ts-node": "^10.9.2"
  }
}
